rod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25095617%2Faltered-story-so-far-3-2.jpg&amp;w=3840&amp;q=75 3840w\" style=\"color:transparent;width:100%;height:auto\" width=\"0\"/></p></div></div></div><div class=\"\" data-attr-widget-name=\"timeline\" id=\"widget0_subwidget1\"><div class=\"flex flex-col md:flex-row gap-4 md:gap-6 px-4 2xl:px-0\"><ul class=\"grid grid-flow-row auto-rows-max grow\"><li class=\"group grid-12 relative\"><div class=\"flex flex-col col-span-2 md:col-span-1\"><span class=\"border-primary-500 border-4 h-5 w-5 block rounded-full shrink-0 mx-auto\"></span><span class=\"w-px h-full block bg-primary-500 mx-auto my-1\"></span><span class=\"border-l-transparent border-r-transparent border-t-primary-500 border-t-[5px] border-l-[5px] border-r-[5px] border-solid h-0 w-0 -mt-1 hidden group-last:block mx-auto\"></span></div><div class=\"pb-4 col-span-10 md:col-span-11\" style=\"opacity:0;transform:translateY(-25%)\"><hgroup class=\"flex items-center gap-1\"><h6 class=\"text-neutral-400 sm-bold-caps\"></h6><h5 class=\"text-neutral-900 title-6\">Septembre</h5></hgroup><div class=\"lg-medium text-neutral-800\"><ul class=\"pl-4 list-disc [&amp;_ul]:list-circle [&amp;_ul_ul]:list-square my-4\">\n<li>Mandjet et l’Armada Occidentale rallient la Cité des Sages, à la demande de Temera Singh</li>\n<li>Des préparatifs sont entrepris pour voyager vers un signal lumineux, apparu au sud-ouest, en survolant une mer ininterrompue de nuages</li>\n</ul></div></div></li><li class=\"group grid-12 relative\"><div class=\"flex flex-col col-span-2 md:col-span-1\"><span class=\"border-primary-500 border-4 h-5 w-5 block rounded-full shrink-0 mx-auto\"></span><span class=\"w-px h-full block bg-primary-500 mx-auto my-1\"></span><span class=\"border-l-transparent border-r-transparent border-t-primary-500 border-t-[5px] border-l-[5px] border-r-[5px] border-solid h-0 w-0 -mt-1 hidden group-last:block mx-auto\"></span></div><div class=\"pb-4 col-span-10 md:col-span-11\" style=\"opacity:0;transform:translateY(-25%)\"><hgroup class=\"flex items-center gap-1\"><h6 class=\"text-neutral-400 sm-bold-caps\"></h6><h5 class=\"text-neutral-900 title-6\">Octobre</h5></hgroup><div class=\"lg-medium text-neutral-800\"><ul class=\"pl-4 list-disc [&amp;_ul]:list-circle [&amp;_ul_ul]:list-square my-4\">\n<li>La flotte asgarthie quitte la Cité des Sages</li>\n<li>Les Corps expéditionnaires explorent un archipel volant, riche en Aérolithe</li>\n<li>En Asgartha, Somayeh Bahman, nouvelle Basilissa, est démocratiquement élue</li>\n</ul></div></div></li><li class=\"group grid-12 relative\"><div class=\"flex flex-col col-span-2 md:col-span-1\"><span class=\"border-primary-500 border-4 h-5 w-5 block rounded-full shrink-0 mx-auto\"></span><span class=\"w-px h-full block bg-primary-500 mx-auto my-1\"></span><span class=\"border-l-transparent border-r-transparent border-t-primary-500 border-t-[5px] border-l-[5px] border-r-[5px] border-solid h-0 w-0 -mt-1 hidden group-last:block mx-auto\"></span></div><div class=\"pb-4 col-span-10 md:col-span-11\" style=\"opacity:0;transform:translateY(-25%)\"><hgroup class=\"flex items-center gap-1\"><h6 class=\"text-neutral-400 sm-bold-caps\"></h6><h5 class=\"text-neutral-900 title-6\">Novembre</h5></hgroup><div class=\"lg-medium text-neutral-800\"><ul class=\"pl-4 list-disc [&amp;_ul]:list-circle [&amp;_ul_ul]:list-square my-4\">\n<li>Parmi tous les Léviathans qui ont élu domicile au sein de l’archipel, l’un d’entre eux, baptisé Halua, attaque systématiquement tous les convois humains</li>\n<li>Une chasse est entreprise pour mettre fin aux ravages d’Halua</li>\n<li>Grâce au Musubi, une chasseresse Bravos se lie avec le Léviathan hostile, et parvient à l’apaiser</li>\n</ul></div></div></li><li class=\"group grid-12 relative\"><div class=\"flex flex-col col-span-2 md:col-span-1\"><span class=\"border-primary-500 border-4 h-5 w-5 block rounded-full shrink-0 mx-auto\"></span><span class=\"w-px h-full block bg-primary-500 mx-auto my-1\"></span><span class=\"border-l-transparent border-r-transparent border-t-primary-500 border-t-[5px] border-l-[5px] border-r-[5px] border-solid h-0 w-0 -mt-1 hidden group-last:block mx-auto\"></span></div><div class=\"pb-4 col-span-10 md:col-span-11\" style=\"opacity:0;transform:translateY(-25%)\"><hgroup class=\"flex items-center gap-1\"><h6 class=\"text-neutral-400 sm-bold-caps\"></h6><h5 class=\"text-neutral-900 title-6\">Décembre</h5></hgroup><div class=\"lg-medium text-neutral-800\"><ul class=\"pl-4 list-disc [&amp;_ul]:list-circle [&amp;_ul_ul]:list-square my-4\">\n<li>Pour atteindre la source du signal lumineux, les Asgarthi doivent passer le Whiplash, une tempête circulaire dont les vents furieux empêchent tout navire de la traverser</li>\n<li>Les Asgarthi parviennent à convoquer tous les Léviathans croisés sur leur route. En se plaçant dans leur sillage, les vaisseaux d’exploration parviennent à passer le Whiplash</li>\n<li>Premier contact avec la civilisation Reka</li>\n</ul></div></div></li></ul></div></div><div class=\"\" data-attr-widget-name=\"content_block\" id=\"widget0_subwidget2\"><div class=\"flex flex-col gap-4 px-4 2xl:px-0 items-center text-center\"><div class=\"flex flex-col gap-2 w-full items-center text-center\"><hgroup class=\"flex flex-col gap-2\"><h1 class=\"text-neutral-900 title-4\">394 AC</h1></hgroup></div><div class=\"md-medium md:lg-medium text-neutral-800 flex flex-col w-full items-center text-center\"><p class=\"my-4 only:my-0 w-full\"><img alt=\"altered-story-so-far-3-3\" data-nimg=\"1\" decoding=\"async\" height=\"0\" loading=\"lazy\" sizes=\"100vw\" src=\"/_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=3840&amp;q=75\" srcset=\"/_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Faltered-cms-prod-eu.s3.eu-west-3.amazonaws.com%2Fwp-content%2Fuploads%2Fsites%2F3%2F2026%2F02%2F25100008%2Faltered-story-so-far-3-3.jpg&amp;w=3840&amp;q=75 3840w\" style=\"color:transparent;width:100%;height:auto\" width=\"0\"/></p></div></div></div><div class=\"\" data-attr-widget-name=\"timeline\" id=\"widget0_subwidget3\"><div class=\"flex flex-col md:flex-row gap-4 md:gap-6 px-4 2xl:px-0\"><ul class=\"grid grid-flow-row auto-rows-max grow\"><li class=\"group grid-12 relative\"><div class=\"flex flex-col col-span-2 md:col-span-1\"><span class=\"border-primary-500 border-4 h-5 w-5 block rounded-full shrink-0 mx-auto\"></span><span class=\"w-px h-full block bg-primary-500 mx-auto my-1\"></span><span class=\"border-l-transparent border-r-transparent border-t-primary-500 border-t-[5px] border-l-[5px] border-r-[5px] border-solid h-0 w-0 -mt-1 hidden group-last:block mx-auto\"></span></div><div class=\"pb-4 col-span-10 md:col-span-11\" style=\"opacity:0;transform:translateY(-25%)\"><hgroup class=\"flex items-center gap-1\"><h6 class=\"text-neutral-400 sm-bold-caps\"></h6><h5 class=\"text-neutral-900 title-6\">Janvier-Février</h5></hgroup><div class=\"lg-medium text-neutral-800\"><ul class=\"pl-4 list-disc [&amp;_ul]:list-circle [&amp;_ul_ul]:list-square my-4\">\n<li>Après deux mois de redécouverte mutuelle et de pourparlers, les deux peuples réunis évoquent la possibilité d’une alliance durable</li>\n<li>De nouveaux Exalts sont déployés vers Asty, le capitale Reka</li>\n</ul></div></div></li></ul></div></div></div></div></div></div></div>",
